{
  "ordering": "auto",
  "model": "opusplan",
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "fastMode": true,
  "autoCompactThreshold": 0.7,
  "teammateMode": "in-process",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/statusline.js"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/state && claude auth status > ~/.claude/state/subscription.json 2>/dev/null",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f .claude/state/session-context.md",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/task-log.js" }]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/task-log.js", "statusMessage": "Tracking agent" }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/task-log.js", "statusMessage": "Completing agent" }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/teammate-quality.js" }]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/teammate-quality.js" }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/task-log.js" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/task-log.js" }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/task-log.js" }]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git tag -d:*)",
      "Bash(git remote:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)"
    ],
    "allow": [
      "WebSearch",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(time:*)",
      "Bash(rsync:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(jq:*)",
      "Bash(date:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(gh auth status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh api graphql:*)",
      "Bash(git log:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git status:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git apply:*)",
      "Bash(pytest:*)",
      "Bash(pre-commit run:*)",
