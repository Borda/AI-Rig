{
  "autoCompactThreshold": 0.7,
  "autoUpdatesChannel": "stable",
  "effortLevel": "high",
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "fastModePerSessionOptIn": false,
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/lint-on-save.js",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Logging tool",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/rtk-rewrite.js",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "find .reports/calibrate .reports/resolve .reports/audit .reports/review .experiments .developments -maxdepth 2 -name 'result.jsonl' -mtime +30 2>/dev/null | xargs dirname | xargs rm -rf; find .plans/blueprint .cache .temp -type f -mtime +30 2>/dev/null | xargs rm -f",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "mkdir -p ~/.claude/state && claude auth status > ~/.claude/state/subscription.json 2>/dev/null",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "rm -f .claude/state/session-context.md",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Tracking agent",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Completing agent",
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/teammate-quality.js",
            "statusMessage": "Quality gate",
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/teammate-quality.js",
            "statusMessage": "Quality gate",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "ordering": "auto",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Read(/tmp/**)",
      "Write(.plans/**)",
      "Write(.notes/**)",
      "Write(.reports/**)",
      "Write(.temp/**)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
