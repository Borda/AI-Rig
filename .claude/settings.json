      "Bash(python -m doctest:*)",
      "Bash(python -m pre_commit run:*)",
      "Bash(python -m cProfile:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pip show:*)",
      "Bash(pip list:*)",
      "Bash(pip index:*)",
      "Bash(pip3 show:*)",
      "Bash(pip3 list:*)",
      "Bash(pip3 index:*)",
