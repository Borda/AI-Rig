{
  "autoCompactThreshold": 0.7,
  "autoUpdatesChannel": "stable",
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "fastModePerSessionOptIn": false,
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/lint-on-save.js",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Logging tool",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "find _calibrate _resolve _audit _review _optimize _develop -maxdepth 2 -name 'result.jsonl' -mtime +30 2>/dev/null | xargs -r dirname | xargs -r rm -rf; find _out -type f -mtime +30 2>/dev/null | xargs -r rm -f; find _out -mindepth 1 -maxdepth 2 -type d -empty 2>/dev/null | xargs -r rmdir",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "mkdir -p ~/.claude/state && claude auth status > ~/.claude/state/subscription.json 2>/dev/null",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "rm -f .claude/state/session-context.md",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Tracking agent",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/task-log.js",
            "statusMessage": "Completing agent",
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/teammate-quality.js",
            "statusMessage": "Quality gate",
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/teammate-quality.js",
            "statusMessage": "Quality gate",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "ordering": "auto",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Read(/tmp/**)",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
