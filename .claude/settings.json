      "Bash(gh run view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh api graphql:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git status:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git apply:*)",
      "Bash(git commit:*)",
      "Bash(git revert:*)",
