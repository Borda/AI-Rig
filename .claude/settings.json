      "Bash(diff:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(time:*)",
      "Bash(rsync:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
