      "Bash(env:*)",
      "Bash(gh auth status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh api graphql:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git status:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git apply:*)",
      "Bash(git commit:*)",
      "Bash(git revert:*)",
      "Bash(pytest:*)",
      "Bash(pre-commit run:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m doctest:*)",
      "Bash(python -m pre_commit run:*)",
      "Bash(python -m cProfile:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pip show:*)",
      "Bash(pip list:*)",
      "Bash(pip index:*)",
      "Bash(pip-audit:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(uv run python -m doctest:*)",
      "Bash(uv run python -m cProfile:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run pre-commit run:*)",
      "Bash(uv run pip-audit:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip check:*)",
      "Bash(uv tree:*)",
      "Bash(comm:*)",
      "Bash(mktemp:*)",
      "Bash(touch:*)",
      "Bash(printf:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(node --check:*)",
      "Bash(find .cache*)",
      "Bash(find .experiments*)",
      "Bash(find .developments*)",
      "Bash(find .notes*)",
      "Bash(find .plans*)",
      "Bash(find .reports*)",
      "Bash(find .temp*)",
      "Bash(mkdir -p .cache/*)",
      "Bash(mkdir -p .notes/)",
      "Bash(mkdir -p .plans/active/)",
      "Bash(mkdir -p .plans/blueprint/)",
      "Bash(mkdir -p .plans/closed/)",
      "Bash(mkdir -p .reports/calibrate/*)",
      "Bash(mkdir -p .reports/resolve/*)",
      "Bash(mkdir -p .reports/audit/*)",
      "Bash(mkdir -p .reports/review/*)",
      "Bash(mkdir -p .reports/analyse/*)",
      "Bash(mkdir -p .experiments/*)",
      "Bash(mkdir -p .developments/*)",
      "Bash(mkdir -p .temp/)",
      "Bash(claude:*)",
      "Bash(node:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:pre-commit.ci)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:hr.linkedin.com)",
      "WebFetch(domain:scholar.google.com)",
      "Skill(sync)",
      "Skill(calibrate)",
      "Bash(cd:*)"
    ],
    "deny": [
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git tag -d:*)",
      "Bash(curl -X DELETE:*)",
      "Bash(curl --request DELETE:*)"
    ]
  },
  "statusLine": {
    "async": true,
    "command": "node .claude/hooks/statusline.js",
    "type": "command"
  },
  "teammateMode": "in-process"
}
