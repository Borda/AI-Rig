      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run pre-commit run:*)",
      "Bash(uv run pip-audit:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip check:*)",
      "Bash(uv tree:*)",
